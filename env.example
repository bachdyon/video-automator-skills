# Copy this file to .env in the repo root, beside jobs/ and skills/.
# OpenAI — Whisper/word-level transcription ($word_timestamps_extractor), text embeddings for the
# asset index (e.g. text-embedding-3-small), and other skills that call the OpenAI API.
# Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — multimodal / vision for asset semantic indexing ($asset_semantic_extractor)
# and video analysis in $video_design_spec_builder. Create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# AusyncLab — cloud TTS / voice for narration via $ausynclab-voice (API key required to call AusyncLab).
# Optional: if missing or empty, agents may use $free-tts (VieNeu-TTS local) instead.
# AUSYNCLAB_VOICE_ID — default voice id for synthesis (list voices in the AusyncLab dashboard).
# https://ausynclab.io
AUSYNCLAB_API_KEY=
AUSYNCLAB_VOICE_ID=

# fal.ai — used by $fal-image-generator to synthesize AI images.
# Sign up at https://fal.ai then create a key in the dashboard.
FAL_API_KEY=

# KIE.AI — used by $create-video-seedance-2-0 and $create-edit-image-gpt-image-2.
# Create an API key at https://kie.ai/ and keep generated assets downloaded locally.
KIE_API_KEY=

# HeyGen — used by $heygen-asset-upload and $heygen-photo-avatar-video (repo-root `.env`).
HEYGEN_API_KEY=

# SocialKit — used by $socialkit-api for transcripts, summaries, stats, comments, search, and downloads.
# Sign up at https://www.socialkit.dev and create an API key in the dashboard.
SOCIALKIT_API_KEY=
